  "emulators": [
    {
      "id": "retroarch",
      "name": "RetroArch",
      "packages": [
        "com.retroarch.aarch64",
        "com.retroarch",
        "com.retroarch.ra32"
      ],
      "launch": {
        "type": "retroarch"
      },
      "installUrl": "https://retroarch.com/?page=platforms"
    },
    {
      "id": "duckstation",
      "name": "DuckStation",
      "packages": [
        "com.github.stenzek.duckstation"
      ],
      "launch": {
        "type": "component_extra",
